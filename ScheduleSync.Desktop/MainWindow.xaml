<Window x:Class="ScheduleSync.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScheduleSync - Crew Assignment"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="ScheduleSync" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Paste a foreman email, load your Prefab Packages CSV, and assign crews to tasks."
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- AI Settings (right side of header) -->
            <Border Grid.Column="1" Background="#F5F5F5" CornerRadius="6" Padding="12,8"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AI" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ApiKeyBox" Width="200" FontSize="11" Padding="4,3"
                             MaxLength="200"
                             GotFocus="ApiKeyBox_GotFocus"
                             LostFocus="ApiKeyBox_LostFocus"
                             Text="Enter OpenAI API key..."
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox x:Name="ModelCombo" Width="130" FontSize="11" Margin="6,0,0,0"
                              SelectedIndex="0">
                        <ComboBoxItem Content="codex-5.3"/>
                        <ComboBoxItem Content="gpt-4.1"/>
                        <ComboBoxItem Content="gpt-4.1-mini"/>
                        <ComboBoxItem Content="gpt-4o"/>
                        <ComboBoxItem Content="gpt-4o-mini"/>
                    </ComboBox>
                    <Ellipse x:Name="AiStatusDot" Width="8" Height="8" Margin="8,0,0,0"
                             Fill="#BDBDBD" VerticalAlignment="Center"
                             ToolTip="AI not configured"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="280"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Inputs -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CSV File Picker -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="SCHEDULE CSV" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CsvPathBox" Grid.Column="0" IsReadOnly="True"
                                     Padding="8,6" FontSize="12"
                                     Text="No file selected..."
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="6,0,0,0"
                                    Click="BrowseCsv_Click"/>
                        </Grid>
                        <TextBlock x:Name="CsvStatusText" FontSize="11" Margin="0,4,0,0"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Email Text Box -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="FOREMAN EMAIL" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="EmailBox"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 Padding="6"/>
                    </DockPanel>
                </Border>

                <!-- Parsed Rules Summary -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,8"
                        MaxHeight="140">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="PARSED RULES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ListBox x:Name="RulesListBox" BorderThickness="0" FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ParseButton" Content="Parse Email" Style="{StaticResource SecondaryButton}"
                            Click="ParseEmail_Click" Margin="0,0,8,0"/>
                    <Button x:Name="MatchButton" Content="Match Crews"
                            Style="{StaticResource PrimaryButton}"
                            Click="MatchCrews_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Right Panel: Results -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="CREW ASSIGNMENTS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="SummaryText" FontSize="12" Margin="0,2,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Push to Project"
                                    Style="{StaticResource PrimaryButton}"
                                    x:Name="PushButton"
                                    Click="PushToProject_Click" IsEnabled="False"
                                    Margin="0,0,8,0"/>
                            <Button Content="Export CSV"
                                    Style="{StaticResource SecondaryButton}"
                                    x:Name="ExportButton"
                                    Click="ExportCsv_Click" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>

                    <!-- MPP File Picker (optional, for Push to Project) -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="8,6"
                            Background="#F5F5F5" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MPP:" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="MppPathBox" Grid.Column="1" IsReadOnly="True"
                                     Padding="4,2" FontSize="11"
                                     Text="(optional) browse or leave blank to use active project"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button Grid.Column="2" Content="Browse"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11"
                                    Margin="6,0,0,0"
                                    Click="BrowseMpp_Click"/>
                        </Grid>
                    </Border>

                    <!-- Results TreeView -->
                    <TreeView x:Name="ResultsTree" BorderThickness="0"
                              FontSize="12">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="Margin" Value="0,1"/>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="StatusBar" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="Ready"/>
        </Border>
    </Grid>
</Window>
