<Window x:Class="ScheduleSync.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="ScheduleSync"
        Width="1600"
        Height="960"
        MinWidth="1200"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#F4F1EA">
    <Grid>
        <wv2:WebView2 x:Name="Browser"
                      Visibility="Collapsed" />

        <Grid x:Name="LoadingPanel"
              Background="#F4F1EA"
              Visibility="Visible">
            <Border Width="520"
                    Padding="40"
                    Background="#FFFDF8"
                    BorderBrush="#D9D0C4"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ScheduleSync"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#24322B" />
                    <TextBlock x:Name="ModeText"
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="#6A6F64"
                               Text="Preparing desktop shell" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,18,0,0"
                               FontSize="16"
                               Foreground="#24322B"
                               Text="Starting up..." />
                    <ProgressBar Margin="0,22,0,0"
                                 Height="10"
                                 IsIndeterminate="True"
                                 Foreground="#2E6B55"
                                 Background="#E7DDD0" />
                    <TextBlock Margin="0,18,0,0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="#6A6F64"
                               Text="The desktop shell starts a local copy of the ScheduleSync web app and keeps all user data under LocalAppData." />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ErrorPanel"
              Background="#F4F1EA"
              Visibility="Collapsed">
            <Border Width="620"
                    Padding="32"
                    Background="#FFF8F6"
                    BorderBrush="#D88A78"
                    BorderThickness="1"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Desktop startup failed"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#7A2F1F" />
                    <TextBlock x:Name="ErrorSummaryText"
                               Margin="0,12,0,0"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Foreground="#40221B" />
                    <TextBox x:Name="ErrorDetailsText"
                             Margin="0,18,0,0"
                             MinHeight="170"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="#FFF8F6"
                             Foreground="#40221B"
                             FontFamily="Consolas"
                             FontSize="12" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">
                        <Button Content="Open Logs"
                                Padding="16,8"
                                Margin="0,0,12,0"
                                Click="OpenLogs_Click" />
                        <Button Content="Retry"
                                Padding="16,8"
                                Click="Retry_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
