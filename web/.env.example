# Reference environment for the ScheduleSync web app.
# The backend does not auto-load this file; export these values in your shell,
# service manager, or deployment platform before starting the app.

# Comma-separated origins allowed to send credentialed browser requests.
SCHEDULESYNC_ALLOWED_ORIGINS=http://localhost:5173

# 32+ random bytes encoded for your secret manager or environment store.
SESSION_COOKIE_SECRET=replace-with-a-long-random-secret

# OIDC provider configuration. Any standards-compliant issuer works.
# If you do not already have an organization IdP, a self-hosted Keycloak realm
# is the default low-cost deployment option for local pilots and small teams.
OIDC_ISSUER_URL=https://id.example.com/realms/schedulesync
OIDC_CLIENT_ID=schedulesync-web
OIDC_CLIENT_SECRET=replace-if-your-provider-requires-a-client-secret
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
OIDC_SCOPES=openid profile email

# Comma-separated email allowlist for bootstrap admin assignment.
OIDC_ADMIN_EMAILS=admin@example.com

# Development-only auth bypass. This is ignored when NODE_ENV=production.
# Use this only for local development when you do not want to configure OIDC yet.
SCHEDULESYNC_DEV_AUTH_BYPASS=0
SCHEDULESYNC_DEV_AUTH_EMAIL=local-dev-user@local.schedulesync.dev
SCHEDULESYNC_DEV_AUTH_NAME=Local Developer
SCHEDULESYNC_DEV_AUTH_ROLE=admin
