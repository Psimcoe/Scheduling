generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                String    @id @default(uuid())
  name              String
  startDate         DateTime
  finishDate        DateTime?
  defaultCalendarId String    @default("__default__")
  scheduleFrom      String    @default("start") // "start" | "finish"
  statusDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tasks        Task[]
  dependencies Dependency[]
  calendars    Calendar[]
  resources    Resource[]
}

model Task {
  id                  String    @id @default(uuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId            String?
  wbsCode             String    @default("")
  outlineLevel        Int       @default(1)
  name                String
  type                String    @default("task") // "task" | "summary" | "milestone"
  durationMinutes     Float     @default(480)
  start               DateTime
  finish              DateTime
  constraintType      Int       @default(0) // Maps to ConstraintType enum
  constraintDate      DateTime?
  calendarId          String?
  percentComplete     Int       @default(0)
  isManuallyScheduled Boolean   @default(false)
  isCritical          Boolean   @default(false)
  totalSlackMinutes   Float     @default(0)
  freeSlackMinutes    Float     @default(0)
  earlyStart          DateTime?
  earlyFinish         DateTime?
  lateStart           DateTime?
  lateFinish          DateTime?
  deadline            DateTime?
  notes               String    @default("")
  externalKey         String?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  baselines        Baseline[]
  assignmentsTo    Assignment[]
  dependenciesFrom Dependency[] @relation("DependencyFrom")
  dependenciesTo   Dependency[] @relation("DependencyTo")

  @@index([projectId])
  @@index([parentId])
  @@index([externalKey])
}

model Dependency {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromTaskId String
  fromTask   Task     @relation("DependencyFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTaskId   String
  toTask     Task     @relation("DependencyTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  type       String   @default("FS") // "FS" | "SS" | "FF" | "SF"
  lagMinutes Float    @default(0)
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([fromTaskId])
  @@index([toTaskId])
}

model Calendar {
  id                  String   @id @default(uuid())
  projectId           String?
  project             Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String
  workingDaysOfWeek   String   @default("[false,true,true,true,true,true,false]") // JSON array
  defaultWorkingHours String   @default("[{\"startTime\":\"08:00\",\"endTime\":\"12:00\"},{\"startTime\":\"13:00\",\"endTime\":\"17:00\"}]") // JSON
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exceptions CalendarException[]

  @@index([projectId])
}

model CalendarException {
  id           String   @id @default(uuid())
  calendarId   String
  calendar     Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  startDate    String // YYYY-MM-DD
  endDate      String // YYYY-MM-DD
  isWorking    Boolean  @default(false)
  workingHours String? // JSON array of WorkingHourRange or null

  @@index([calendarId])
}

model Resource {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  type       String   @default("work") // "work" | "material"
  maxUnits   Float    @default(1.0)
  calendarId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assignments Assignment[]

  @@index([projectId])
}

model Assignment {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  units       Float    @default(1.0)
  workMinutes Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([resourceId])
}

model Baseline {
  id                      String   @id @default(uuid())
  taskId                  String
  task                    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  baselineIndex           Int      @default(0) // 0–10
  baselineStart           DateTime
  baselineFinish          DateTime
  baselineDurationMinutes Float
  createdAt               DateTime @default(now())

  @@unique([taskId, baselineIndex])
  @@index([taskId])
}

model UndoEntry {
  id        String   @id @default(uuid())
  projectId String
  label     String
  snapshot  String // JSON snapshot of affected rows
  position  Int // Stack position
  createdAt DateTime @default(now())

  @@index([projectId, position])
}
