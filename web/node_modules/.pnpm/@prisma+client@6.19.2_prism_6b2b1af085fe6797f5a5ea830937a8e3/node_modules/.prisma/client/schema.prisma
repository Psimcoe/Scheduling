generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Project
// ---------------------------------------------------------------------------

model Project {
  id                      String    @id @default(uuid())
  name                    String
  startDate               DateTime
  finishDate              DateTime?
  defaultCalendarId       String    @default("__default__")
  scheduleFrom            String    @default("start") // "start" | "finish"
  statusDate              DateTime?
  undoPointer             Int? // current position in undo stack
  // Project-level scheduling settings
  currencySymbol          String    @default("$")
  minutesPerDay           Int       @default(480)
  minutesPerWeek          Int       @default(2400)
  daysPerMonth            Int       @default(20)
  defaultTaskType         String    @default("fixedUnits") // fixedDuration | fixedWork | fixedUnits
  defaultFixedCostAccrual String    @default("prorated") // start | end | prorated
  honorConstraints        Boolean   @default(true)
  newTasksEffortDriven    Boolean   @default(false)
  autolink                Boolean   @default(false)
  criticalSlackLimit      Int       @default(0) // days; tasks with total slack ≤ this are critical
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tasks        Task[]
  dependencies Dependency[]
  calendars    Calendar[]
  resources    Resource[]

  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Task
// ---------------------------------------------------------------------------

model Task {
  id                  String    @id @default(uuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId            String?
  wbsCode             String    @default("")
  outlineLevel        Int       @default(1)
  name                String
  type                String    @default("task") // "task" | "summary" | "milestone"
  durationMinutes     Float     @default(480)
  start               DateTime
  finish              DateTime
  constraintType      Int       @default(0) // Maps to ConstraintType enum 0-7
  constraintDate      DateTime?
  calendarId          String?
  percentComplete     Int       @default(0)
  isManuallyScheduled Boolean   @default(false)
  isCritical          Boolean   @default(false)
  totalSlackMinutes   Float     @default(0)
  freeSlackMinutes    Float     @default(0)
  earlyStart          DateTime?
  earlyFinish         DateTime?
  lateStart           DateTime?
  lateFinish          DateTime?
  deadline            DateTime?
  notes               String    @default("")
  externalKey         String?
  sortOrder           Int       @default(0)

  // Actuals — for progress tracking
  actualStart           DateTime?
  actualFinish          DateTime?
  actualDurationMinutes Float     @default(0)
  actualWork            Float     @default(0) // in minutes
  actualCost            Float     @default(0)
  remainingDuration     Float     @default(0) // in minutes
  remainingWork         Float     @default(0) // in minutes
  remainingCost         Float     @default(0)

  // Cost
  fixedCost        Float  @default(0)
  fixedCostAccrual String @default("prorated") // start | end | prorated
  cost             Float  @default(0) // total calculated cost
  work             Float  @default(0) // total calculated work (minutes)

  // Task mode
  taskMode       String  @default("fixedUnits") // fixedDuration | fixedWork | fixedUnits
  isEffortDriven Boolean @default(false)
  isActive       Boolean @default(true)

  // Earned value
  bcws                    Float @default(0)
  bcwp                    Float @default(0)
  acwp                    Float @default(0)
  physicalPercentComplete Int   @default(0) // 0-100; alternate EV method

  // Earned value — computed
  sv  Float @default(0) // Schedule Variance = BCWP - BCWS
  cv  Float @default(0) // Cost Variance = BCWP - ACWP
  spi Float @default(0) // Schedule Performance Index = BCWP / BCWS
  cpi Float @default(0) // Cost Performance Index = BCWP / ACWP
  eac Float @default(0) // Estimate At Completion
  vac Float @default(0) // Variance At Completion = BAC - EAC

  // Split task support
  isSplit Boolean @default(false)

  // Recurring task reference
  isRecurring      Boolean @default(false)
  recurringPattern String? // JSON: {frequency, interval, daysOfWeek, occurrences, rangeEnd}

  // Hyperlinks
  hyperlink        String @default("")
  hyperlinkAddress String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  baselines         Baseline[]
  assignmentsTo     Assignment[]
  dependenciesFrom  Dependency[]       @relation("DependencyFrom")
  dependenciesTo    Dependency[]       @relation("DependencyTo")
  customFieldValues CustomFieldValue[]
  interimPlans      InterimPlan[]
  timephasedData    TimephasedData[]
  splits            TaskSplit[]

  @@index([projectId])
  @@index([parentId])
  @@index([externalKey])
}

// ---------------------------------------------------------------------------
// Dependency
// ---------------------------------------------------------------------------

model Dependency {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromTaskId String
  fromTask   Task     @relation("DependencyFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTaskId   String
  toTask     Task     @relation("DependencyTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  type       String   @default("FS") // "FS" | "SS" | "FF" | "SF"
  lagMinutes Float    @default(0)
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([fromTaskId])
  @@index([toTaskId])
}

// ---------------------------------------------------------------------------
// Calendar
// ---------------------------------------------------------------------------

model Calendar {
  id                  String   @id @default(uuid())
  projectId           String?
  project             Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String
  workingDaysOfWeek   String   @default("[false,true,true,true,true,true,false]") // JSON bool[7]
  defaultWorkingHours String   @default("[{\"startTime\":\"08:00\",\"endTime\":\"12:00\"},{\"startTime\":\"13:00\",\"endTime\":\"17:00\"}]") // JSON
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exceptions CalendarException[]

  @@index([projectId])
}

model CalendarException {
  id           String   @id @default(uuid())
  calendarId   String
  calendar     Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  startDate    String // YYYY-MM-DD
  endDate      String // YYYY-MM-DD
  isWorking    Boolean  @default(false)
  workingHours String? // JSON array of WorkingHourRange or null

  @@index([calendarId])
}

// ---------------------------------------------------------------------------
// Resource
// ---------------------------------------------------------------------------

model Resource {
  id           String  @id @default(uuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  type         String  @default("work") // "work" | "material" | "cost"
  initials     String  @default("")
  group        String  @default("")
  emailAddress String  @default("")
  maxUnits     Float   @default(1.0)
  calendarId   String?

  // Cost rates
  standardRate  Float  @default(0) // per hour
  overtimeRate  Float  @default(0) // per hour
  costPerUse    Float  @default(0)
  costRateTable String @default("[]") // JSON — tables A-E with effective dates
  accrueAt      String @default("prorated") // start | end | prorated

  // Budget
  budgetCost Float   @default(0)
  budgetWork Float   @default(0) // in minutes
  isBudget   Boolean @default(false)
  isGeneric  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments Assignment[]

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Assignment
// ---------------------------------------------------------------------------

model Assignment {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  units       Float    @default(1.0)
  workMinutes Float    @default(0)

  // Actuals
  actualWork    Float @default(0)
  actualCost    Float @default(0)
  remainingWork Float @default(0)
  remainingCost Float @default(0)

  // Scheduling
  start              DateTime?
  finish             DateTime?
  delay              Float     @default(0) // leveling delay in minutes
  costRateTableIndex Int       @default(0) // 0=A, 1=B, 2=C, 3=D, 4=E
  contour            String    @default("flat") // flat|backLoaded|frontLoaded|bell|turtle|earlyPeak|latePeak|doublePeak

  createdAt DateTime @default(now())

  timephasedData TimephasedData[]

  @@index([taskId])
  @@index([resourceId])
}

// ---------------------------------------------------------------------------
// Baseline
// ---------------------------------------------------------------------------

model Baseline {
  id                      String   @id @default(uuid())
  taskId                  String
  task                    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  baselineIndex           Int      @default(0) // 0–10
  baselineStart           DateTime
  baselineFinish          DateTime
  baselineDurationMinutes Float
  baselineWork            Float    @default(0) // in minutes
  baselineCost            Float    @default(0)
  createdAt               DateTime @default(now())

  @@unique([taskId, baselineIndex])
  @@index([taskId])
}

// ---------------------------------------------------------------------------
// Undo/Redo
// ---------------------------------------------------------------------------

model UndoEntry {
  id           String   @id @default(uuid())
  projectId    String
  description  String   @default("") // human-readable label
  snapshotJson String // JSON snapshot of full project state
  position     Int // Stack position
  createdAt    DateTime @default(now())

  @@index([projectId, position])
}

// ---------------------------------------------------------------------------
// Custom Fields
// ---------------------------------------------------------------------------

model CustomFieldDefinition {
  id              String   @id @default(uuid())
  projectId       String
  fieldName       String // e.g. "Text1", "Number3", "Flag2", "OutlineCode1"
  displayName     String   @default("")
  fieldType       String // "text" | "number" | "date" | "flag" | "cost" | "duration" | "outlineCode"
  formula         String? // safe expression formula or null
  lookupTableJson String? // JSON array of {value, description, parentValue}
  indicatorRules  String? // JSON graphical indicator rules
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  values CustomFieldValue[]

  @@unique([projectId, fieldName])
  @@index([projectId])
}

model CustomFieldValue {
  id      String                @id @default(uuid())
  taskId  String
  task    Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fieldId String
  field   CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  textValue   String?
  numberValue Float?
  dateValue   DateTime?
  flagValue   Boolean?

  @@unique([taskId, fieldId])
  @@index([taskId])
  @@index([fieldId])
}

// ---------------------------------------------------------------------------
// InterimPlan — snapshots for "interim plan" comparisons (up to 10)
// ---------------------------------------------------------------------------

model InterimPlan {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  planIndex Int // 1-10 (maps to Interim Plan 1 through 10)
  start     DateTime
  finish    DateTime
  createdAt DateTime @default(now())

  @@unique([taskId, planIndex])
  @@index([taskId])
}

// ---------------------------------------------------------------------------
// TimephasedData — time-distributed work/cost data per assignment or task
// ---------------------------------------------------------------------------

model TimephasedData {
  id           String      @id @default(uuid())
  taskId       String?
  task         Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  type         String // "work" | "actualWork" | "cost" | "actualCost" | "baselineWork" | "baselineCost"
  startDate    DateTime
  endDate      DateTime
  value        Float       @default(0) // value for the period (minutes for work, currency for cost)
  unit         String      @default("minutes") // "minutes" | "hours" | "currency"
  createdAt    DateTime    @default(now())

  @@index([taskId])
  @@index([assignmentId])
}

// ---------------------------------------------------------------------------
// TaskSplit — segments for split tasks
// ---------------------------------------------------------------------------

model TaskSplit {
  id              String   @id @default(uuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  segmentIndex    Int // 0-based segment number
  start           DateTime
  finish          DateTime
  durationMinutes Float    @default(0)
  createdAt       DateTime @default(now())

  @@unique([taskId, segmentIndex])
  @@index([taskId])
}

// ---------------------------------------------------------------------------
// AI — Patterns, Conversations, Feedback
// ---------------------------------------------------------------------------

model AiPattern {
  id              String   @id @default(uuid())
  projectId       String? // null = global pattern
  patternType     String // "naming" | "duration" | "dependency" | "resource" | "sequence"
  pattern         String // JSON — shape depends on patternType
  confidence      Float    @default(0.5) // 0-1 confidence score
  occurrenceCount Int      @default(1)
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([patternType])
  @@index([projectId])
}

model AiConversation {
  id        String   @id @default(uuid())
  projectId String
  messages  String // JSON array of {role, content, timestamp}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model AiFeedback {
  id             String   @id @default(uuid())
  projectId      String?
  suggestionType String // "duration" | "dependency" | "name" | "resource" | "general"
  suggestion     String // JSON — what was suggested
  accepted       Boolean
  correctedValue String? // what the user chose instead (if rejected)
  createdAt      DateTime @default(now())

  @@index([projectId])
  @@index([suggestionType])
}
