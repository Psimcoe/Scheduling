{
  "name": "@schedulesync/root",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @schedulesync/backend dev & pnpm --filter @schedulesync/frontend dev",
    "setup:windows": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Setup-WebWorkspace.ps1",
    "setup:launch": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Setup-WebWorkspace.ps1 -Launch",
    "dev:windows": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Launch-WebApp.ps1 -Mode Launch",
    "dev:backend": "pnpm --filter @schedulesync/backend dev",
    "dev:frontend": "pnpm --filter @schedulesync/frontend dev",
    "db:generate": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Invoke-BackendPrisma.ps1 generate",
    "db:deploy": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Invoke-BackendPrisma.ps1 migrate deploy",
    "db:push": "powershell -NoLogo -ExecutionPolicy Bypass -File ../scripts/Invoke-BackendPrisma.ps1 db push",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @schedulesync/frontend test:e2e",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "node-llama-cpp",
      "prisma"
    ]
  }
}
