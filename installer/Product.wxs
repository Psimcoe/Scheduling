<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="ScheduleSync Desktop"
    Manufacturer="ScheduleSync"
    Version="$(var.ProductVersion)"
    UpgradeCode="6C34C289-51D3-448A-8D72-8296D2AE6E2A"
    Scope="perMachine">
    <MajorUpgrade DowngradeErrorMessage="A newer version of ScheduleSync Desktop is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ScheduleSync Desktop" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="ScheduleSync Desktop" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="ScheduleSync Desktop" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**">
        <Exclude Files="**\*.map" />
      </Files>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="ProgramMenuDir">
      <Component Id="StartMenuShortcutComponent" Guid="*">
        <Shortcut
          Id="StartMenuShortcut"
          Name="ScheduleSync Desktop"
          Target="[INSTALLFOLDER]ScheduleSync.Desktop.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="ProgramMenuShortcutFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ScheduleSync\Desktop"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
